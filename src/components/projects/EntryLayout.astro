---
import type { ProjectEntry } from '@/types';
import { Image } from 'astro:assets';
import BaseLayout from '@components/base/BaseLayout.astro';
import { formatDate } from '@lib/formatDate';
import ProjectInfo from './ProjectInfo.astro';
import PageHeader from '@components/common/PageHeader.astro';
import TechTable from '@components/common/TechTable.astro';
import ProjectSection from './ProjectSection.astro';
import { PROJECT_SECTION } from '@/i18n/locales/projectSection';
import { getLangFromAstro } from '@/i18n/utils';

interface Props {
  entry: ProjectEntry;
}

const { entry } = Astro.props;
const {
  title,
  resume,
  date,
  imageCover,
  imageCoverAlt,
  categories,
  author,
  stack,
  description,
  content,
  github,
  link,
  platform,
  diagrama: diagram,
  gallery,
} = entry.data;
const entryDate = date ? formatDate(date) : '';
const lang = getLangFromAstro(Astro);
const projectSection = PROJECT_SECTION[lang];
---

<BaseLayout title={title}>
  <PageHeader title={title} />
  <section class='section'>
    <div class='container'>
      <div class='row justify-center'>
        <article class='lg:col-10 flex flex-wrap content-start'>
          <!-- Cover Photo -->
          {
            imageCover && (
              <div class='col basis-2/3 p-2 min-w-72'>
                <div class='glass rounded-lg intersect:animate-fadeDown'>
                  {/* Imagen de fondo con blur */}
                  <div
                    class='absolute inset-0 bg-cover bg-center filter blur-xs opacity-50'
                    style={`background-image: url(${imageCover.src || imageCover})`}
                  />
                  <div class='relative z-10 flex items-center justify-center h-[500px]'>
                    <Image
                      class='max-h-full max-w-full object-contain'
                      src={imageCover}
                      alt={imageCoverAlt}
                      width={1920}
                      height={1080}
                      loading='eager'
                    />
                  </div>
                </div>
              </div>
            )
          }
          <!-- About Project-->
          <ProjectInfo
            author={author}
            entryDate={entryDate}
            categories={categories}
            github={github}
            link={link}
            resume={resume}
            platform={platform}
          />
          <!-- Descripcion -->
          {
            description && (
              <ProjectSection
                titleSection={projectSection.titleDescriptionSection}
                resumeSection={description}
              />
            )
          }
          <!-- Diagrama -->
          {
            diagram && (
              <ProjectSection
                titleSection={projectSection.titleArchitectureSection}
                resumeSection={diagram.resume}
                imgSection={diagram.image}
                imgAltSection={diagram.imageAlt}
                diagramaComponent={diagram.diagramaComponent}
              />
            )
          }
          <!-- Contenido -->
          {
            content && (
              <ProjectSection
                titleSection={projectSection.titleContentSection}
                resumeSection={
                  content.description
                    ? content.description
                    : projectSection.resumeContentSection
                }
                itemSection={content.item}
              />
            )
          }
          <!-- Tecnologias -->
          {
            stack && (
              <section class='col basis-1/3 p-2 min-w-72'>
                <div class='glass rounded-lg p-4 intersect:animate-fadeUp  '>
                  <h2 class='mb-2'>{projectSection.titleTechnologySection}</h2>
                  <hr class='my-1' />
                  <TechTable techs={stack} />
                  <hr class='my-1' />
                </div>
              </section>
            )
          }
          <!-- Gallery -->
          {
            gallery && (
              <ProjectSection
                titleSection={projectSection.titleGallerySection}
                resumeSection={projectSection.resumeGallerySection}
                gallery={gallery}
              />
            )
          }
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
