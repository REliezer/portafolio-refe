---
import { upperHumanize, markdownify, slugify } from "@lib/textConverter";
import { getLangFromAstro, localizeUrl, type Language } from "@/i18n/utils";
import { CATEGORY_LABELS } from "@/i18n/locales/categories";
import ProjectInfoItem from "./ProjectInfoItem.astro";

interface Props {
    author?: string;
    entryDate?: string;
    categories?: string[];
    github?: { title?: string; link: string }[];
    link?: string;
    resume?: string;
    platform?: Record<string, boolean>;
}

const { author, entryDate, categories, github, link, resume, platform }: Props = Astro.props;
const activePlatforms = Object.entries(platform || {})
  .filter(([_, value]) => value)
  .map(([key]) => (key));

const platformIcons: Record<string, string> = {
  web: "🌐",
  movil: "📱",
  nativo: "🖥️",
  pwa: "⚡",
  desktop: "💻",
  api: "🔗",
};

const lang = getLangFromAstro(Astro);
const getCategoryLabel = (key: string, lang: Language) =>
  CATEGORY_LABELS[lang]?.[key] ?? key;
---

<section class="col basis-1/3 p-2 min-w-72 lg:h-[500px]">
    <div class="glass rounded-lg p-2 intersect:animate-fadeUp lg:h-[500px] lg:overflow-y-auto lg:overflow-x-hidden ">
        <!-- Author -->
        {
        author && (
            <ProjectInfoItem
                icon="user"
                title={author}
                url={`/about/`}
            />
        )}
        <!-- Date -->
        {
        entryDate && (
            <ProjectInfoItem
                icon="clock"
                title={entryDate}
            />
        
        )}
        <!-- Platform -->
        {
        platform && (
            <ProjectInfoItem
                icon="folder"
                title={lang === "es" ? "Plataforma" : "Platform"}
            />
            <div class="row m-4">
                <div class="col-12 pl-8">
                    <ul class="list-none space-y-1">
                        {activePlatforms.map((plat) => (
                        <li class="flex items-center">
                            <span class="mr-2" style="list-style: none;">{platformIcons[plat] || "❓"}</span>
                            {upperHumanize(plat)}
                        </li>
                        ))}
                    </ul>
                </div>
            </div>
            )
        }
        <!-- Categories -->
        {
        categories && (
            <ProjectInfoItem
                icon="folder"
                title={lang === "es" ? "Categorías" : "Categories"}
            />
            <div class="row m-4">
                <div class="col-12 pl-10">
                {categories?.map((categoryKey: string) => (
                    categoryKey ? (
                    <li>
                        <a href={localizeUrl(`/projects/categories/${categoryKey}`, lang)} class="hover:text-[#AA367C] hover:underline hover:cursor-pointer focus:outline-none transition-colors duration-200 opacity-100">
                            {upperHumanize(getCategoryLabel(categoryKey, lang))}
                        </a>
                    </li>
                    ) : null
                ))}
                </div>
            </div>
        )
        }
        <!-- GitHub -->
        {
        github && (
            <div>
                {github.length <= 2 ? (
                    {/* Si hay 2 o menos enlaces, mostrar todos directamente */}
                    {github.map((git: { title?: string; link: string }) => (
                        <ProjectInfoItem
                            icon="github"
                            title={git.title ? git.title : lang === "es" ? "Repositorio GitHub" : "GitHub Repository"}
                            url={git.link}
                        />                                      
                    ))}
                ) : (
                    <details class="m-4">
                        <summary
                            class="hover:text-[#AA367C] hover:underline hover:cursor-pointer focus:outline-none transition-colors duration-200"
                        >
                            {lang === "es" ? `Repositorios GitHub (${github.length})` : `GitHub Repositories (${github.length})`}
                        </summary>
                        {github.map((git: { title?: string; link: string }) => (
                            <ProjectInfoItem
                                icon="github"
                                title={git.title ? git.title : lang === "es" ? "Repositorio GitHub" : "GitHub Repository"}
                                url={git.link}
                            />                                      
                        ))}
                    </details>
                )}
            </div>  
        )
        }
        <!-- Link -->
        {
        link && (
            <ProjectInfoItem
                icon="link"
                title={lang === "es" ? "Enlace al proyecto" : "Project Link"}
                url={link}
            />
        )
        }
        <!-- Description -->
        {
        resume && (
            <div>
            {author ? <hr class="my-2" /> : null}
            <div class="m-4">
                <div set:html={markdownify(resume)} />
            </div>
            </div>
        )
        }
    </div>
</section>