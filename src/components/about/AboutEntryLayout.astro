---
import type { AboutEntry } from "@/types";
import { getLangFromAstro } from "@/i18n/utils";

interface Props {
  entry: AboutEntry;
}

const { entry } = Astro.props;
const { title, description } = entry.data;

const lang = getLangFromAstro(Astro);
const labels = lang === "es"
  ? { more: "Leer más...", less: "Leer menos..." }
  : { more: "Read more...", less: "Read less..." };
---

<section class="container mb-6" id="about" data-about>
  <h2 class="font-bold text-right">{title}</h2>
  <hr class="mb-6 hr-separator" />
  <div
    id="about-content"
    class="about-transition text-sm md:text-lg leading-relaxed text-left w-full"
    data-about-content
    set:html={description?.replace(/\n/g, "<br />")}
  />
  <button
    type="button"
    class="btn-more mt-2"data-about-btn
    aria-expanded="false"
    aria-controls="about-content"
    data-more={labels.more}
    data-less={labels.less}
  >
    {labels.more}
  </button>
</section>

<style>
  .about-transition {
    height: 10rem;
    overflow: hidden;
    transition:
      height 400ms cubic-bezier(0.22, 0.9, 0.32, 1),
      opacity 260ms ease;
    opacity: 0.92;
  }

  .about-transition.expanded {
    opacity: 1;
  }
</style>

<script is:client>
  function initAbout(root) {
    const btn = root.querySelector("[data-about-btn]");
    const content = root.querySelector("[data-about-content]");
    if (!(btn instanceof HTMLButtonElement) || !(content instanceof HTMLElement)) return;

    const more = btn.dataset.more || "Read more...";
    const less = btn.dataset.less || "Read less...";

    if (btn.dataset.bound === "true") return;
    btn.dataset.bound = "true";

    const COLLAPSED_HEIGHT = "10rem";

    const setCollapsed = () => {
      content.style.height = COLLAPSED_HEIGHT;
    };

    setCollapsed();

    const toggle = () => {
      const expanded = content.classList.toggle("expanded");

      if (expanded) {
        content.style.height = `${content.scrollHeight}px`;
        btn.textContent = less;
        btn.setAttribute("aria-expanded", "true");
      } else {
        // Contraer
        content.style.height = `${content.scrollHeight}px`;
        content.offsetHeight; // reflow
        setCollapsed();
        btn.textContent = more;
        btn.setAttribute("aria-expanded", "false");
      }
    };

    btn.addEventListener("click", toggle);

    content.addEventListener("transitionend", (e) => {
      if (e.propertyName === "height" && content.classList.contains("expanded")) {
        content.style.height = "auto";
      }
    });

    window.addEventListener("resize", () => {
      if (!content.classList.contains("expanded")) setCollapsed();
      if (content.classList.contains("expanded") && content.style.height !== "auto") {
        content.style.height = `${content.scrollHeight}px`;
      }
    });
  }

  function initAllAbout() {
    document.querySelectorAll("[data-about]").forEach(initAbout);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllAbout, { once: true });
  } else {
    initAllAbout();
  }

  document.addEventListener("astro:page-load", initAllAbout);
</script>