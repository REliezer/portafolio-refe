---
import Analytics from '@vercel/analytics/astro';

import { plainify } from "@lib/textConverter";
import Footer from "@components/base/Footer.astro";
import Header from "@components/base/Header.astro";
import "@/styles/main.css";
import { ClientRouter } from "astro:transitions";
import Background from "@/components/base/Background.astro";
import { Tooltips } from "astro-tooltips";
import ObserverScript from "./ObserverScript.astro";
import PageHeader from "@components/base/PageHeader.astro";
import { getLangFromAstro, getAlternateRoutes } from "@/i18n/utils";

export interface Props {
  title?: string;
  description?: string | null;
  lang?: string;
}
const lang = getLangFromAstro(Astro);
const { pathname } = Astro.url;

const { title, description } = Astro.props;

const siteTitle = lang === "es" ? "Portafolio | Rodrigo Fúnes" : "Portfolio | Rodrigo Fúnes";
const siteDescription = lang === "es" ? "Desarrollador web enfocado en crear soluciones de valor." : "Web developer focused on creating valuable solutions.";

const siteAuthor = "Rodrigo Fúnes";
const baseUrl = "https://portafolio-refe.vercel.app";

const siteImage = new URL("/og-image.png", baseUrl).toString();

const currentPath = Astro.url.pathname;
const alternateRoutes = getAlternateRoutes(currentPath, lang);

const canonicalUrl = new URL(currentPath, baseUrl).toString();

// Alternates absolutos (hreflang)
const alternateAbs = Object.fromEntries(
  Object.entries(alternateRoutes).map(([l, p]) => [l, new URL(p, baseUrl).toString()])
);

const homePaths = new Set(["/", "/en"]);
const normalizedPath = pathname !== "/" && pathname.endsWith("/") ? pathname.slice(0, -1) : pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- SEO: canonical + hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={alternateAbs.es} />
    <link rel="alternate" hreflang="en" href={alternateAbs.en} />
    <link rel="alternate" hreflang="x-default" href={alternateAbs.es} />

    <meta name="robots" content="index,follow" />

    <meta name="theme-name" content="pages" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />

    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <title> {plainify(title ? title : siteTitle)} </title>
    <meta name="description" content={plainify(description ? description : siteDescription)} />
    <meta name="author" content={siteAuthor} />

    <!-- Facebook Meta Tags -->
    <meta property="og:title" content={plainify(title ? title : siteTitle)} />
    <meta property="og:description" content={plainify(description ? description : siteDescription)} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:image" content={siteImage} />
    <meta property="og:site_name" content={lang === "es" ? "Portafolio | Rodrigo Fúnes" : "Portfolio | Rodrigo Fúnes"} />
    
    <!-- Twitter -->
    <meta name="twitter:title" content={plainify(title ? title : siteTitle)} />
    <meta name="twitter:description" content={plainify(description ? description : siteDescription)} />
    <meta name="twitter:image" content={siteImage} />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- JSON-LD (opcional pero recomendable) -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: lang === "es" ? "Portafolio | Rodrigo Fúnes" : "Portfolio | Rodrigo Fúnes",
        url: baseUrl,
        inLanguage: lang,
        author: {
          "@type": "Person",
          name: siteAuthor,
          url: baseUrl,
        },
      })}
    </script>
    
    <ClientRouter fallback="swap" />
    <Tooltips interactive={false} delay={[333, 0]} />
  </head>
  <body>
    <Background />
    {homePaths.has(normalizedPath) ? <Header /> : <PageHeader />}
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <ObserverScript />
    <Analytics />
  </body>
</html>
