---
import { lowerHumanize } from "@lib/textConverter";

const { currentLocale } = Astro;
const { className }: { className?: string } = Astro.props;

const rawPaths = Astro.url.pathname.split("/").filter((x) => x);

const LANGS = ["en", "es"];
const hasLeadingLang = rawPaths.length > 0 && LANGS.includes(rawPaths[0].toLowerCase());
// Si hay un idioma al inicio, eliminamos ese segmento y además
// limpiamos sufijos '-en'|'_en' Y el sufijo directo 'en' (sin separador).
// Si NO hay idioma al inicio, solo eliminamos sufijos con separador.
let paths = rawPaths
  .slice(hasLeadingLang ? 1 : 0)
  .map((seg) => {
    // quitar '-en' o '_en' al final (si existe)
    let cleaned = seg.replace(new RegExp(`[-_](${LANGS.join("|")})$`, "i"), "");
    // si había idioma al inicio, también quitar sufijo directo 'en'/'es' (sin separador)
    if (hasLeadingLang) {
      cleaned = cleaned.replace(new RegExp(`(${LANGS.join("|")})$`, "i"), "");
    }
    return cleaned;
  })
  .filter((s) => s && s.length > 0);

// Depuración (dejar solo durante desarrollo si se necesita)
console.log("Breadcrumbs pathname:", Astro.url.pathname);
console.log("Breadcrumbs paths (raw):", rawPaths);
console.log("Breadcrumbs paths (clean):", paths);
let parts = [
  {
    label: currentLocale === "es" ? "Inicio" : "Home",
    href: currentLocale === "es" ? "/" : `/${currentLocale}/`,
    "aria-label": Astro.url.pathname === "/" ? "page" : undefined,
  },
];

paths.forEach((label: string, i: number) => {
  const href = `${currentLocale === "es" ? "/" : `/${currentLocale}/`}${paths.slice(0, i + 1).join("/")}`;
  label !== "page" &&
    parts.push({
      label: lowerHumanize(label.replace(/[-_]/g, " ")) || "",
      href,
      "aria-label": Astro.url.pathname === href ? "page" : undefined,
    });
});
---

<nav aria-label="Breadcrumb" class={className}>
  <ol class="inline-flex" role="list">
    {
      parts.map(({ label, ...attrs }, index) => (
        <li class="mx-1 capitalize" role="listitem">
          {index > 0 && <span class="inline-block mr-1">/</span>}
          {index !== parts.length - 1 ? (
            <a class="text-text-base dark:text-dark-text-base" {...attrs}>
              {label}
            </a>
          ) : (
            <span class="text-txt-light dark:text-darkmode-txt-light">
              {label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
