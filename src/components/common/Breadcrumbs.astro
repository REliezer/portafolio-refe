---
import { lowerHumanize } from "@lib/textConverter";

const { currentLocale } = Astro;
const { className }: { className?: string } = Astro.props;

const rawPaths = Astro.url.pathname.split("/").filter((x) => x);

const LANGS = ["en", "es"];
const hasLeadingLang = rawPaths.length > 0 && LANGS.includes(rawPaths[0].toLowerCase());

// Delete the prefix of language if it exists.
let paths = rawPaths
  .slice(hasLeadingLang ? 1 : 0)
  .filter((s) => s && s.length > 0);

const base = currentLocale === "es" ? "" : `/${currentLocale}`;
const parts = [
  {
    label: currentLocale === "es" ? "Inicio" : "Home",
    href: base || "/",
    "aria-label": Astro.url.pathname === (base || "/") ? "page" : undefined,
  },
];

paths.forEach((segment: string, i: number) => {
  const href = `${base}/${paths.slice(0, i + 1).join("/")}` || "/";
  parts.push({
    label: lowerHumanize(segment.replace(/[-_]/g, " ")) || "",
    href,
    "aria-label": Astro.url.pathname === href ? "page" : undefined,
  });
});
---

<nav aria-label="Breadcrumb" class={className}>
  <ol class="inline-flex" role="list">
    {
      parts.map(({ label, ...attrs }, index) => (
        <li class="mx-1 capitalize" role="listitem">
          {index > 0 && <span class="inline-block mr-1">/</span>}
          {index !== parts.length - 1 ? (
            <a class="text-text-base dark:text-dark-text-base" {...attrs}>
              {label}
            </a>
          ) : (
            <span class="text-txt-light dark:text-darkmode-txt-light">
              {label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
