---
import BaseLayout from "@components/base/BaseLayout.astro";
import type { ContactEntry } from "@/types";
import { Image } from "astro:assets";
import ContactForm from "./Contact.tsx";
import { CONTACT_FORM_LABELS } from '@/i18n/locales/contactForm';
import { getLangFromAstro } from '@/i18n/utils';

interface Props {
  entry: ContactEntry;
}

const { entry } = Astro.props;
const { image, imageAlt, title } = entry.data;
const lang = getLangFromAstro(Astro);
const labels = CONTACT_FORM_LABELS[lang];
const siteTitle = lang === "es" ? "Contacto | Portafolio Rodrigo Fúnes" : "Contact | Rodrigo Fúnes Portfolio";
---

<BaseLayout title={siteTitle}>
  <ContactForm client:only="react" title={title} labels={labels}>
    <Image
      class="mb-6 w-[92%]"
      src={image!}
      alt={imageAlt}
      width={1024}
      height={1024}
      loading="eager"
    />
  </ContactForm>  
</BaseLayout>
